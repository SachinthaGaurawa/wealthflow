{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=(), payment=(), usb=(), bluetooth=(), accelerometer=(), gyroscope=(), magnetometer=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "X-DNS-Prefetch-Control", "value": "off" }
      ]
    },
    {
      "source": "/(.*\.(js|json|html))",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/sw.js",
      "destination": "/sw.js"
    },
    {
      "source": "/wealthflow-scanner.js",
      "destination": "/wealthflow-scanner.js"
    },
    {
      "source": "/wealthflow-ai-v4.js",
      "destination": "/wealthflow-ai-v4.js"
    },
    {
      "source": "/wealthflow-ai-v6.js",
      "destination": "/wealthflow-ai-v6.js"
    },
    {
      "source": "/wealthflow-ml.js",
      "destination": "/wealthflow-ml.js"
    },
    {
      "source": "/wealthflow-allocator.js",
      "destination": "/wealthflow-allocator.js"
    },
    {
      "source": "/wealthflow-crypto.js",
      "destination": "/wealthflow-crypto.js"
    },
    {
      "source": "/wealthflow-ai-memory.js",
      "destination": "/wealthflow-ai-memory.js"
    },
    {
      "source": "/wealthflow-category-ai.js",
      "destination": "/wealthflow-category-ai.js"
    },
    {
      "source": "/wealthflow-card-registry.js",
      "destination": "/wealthflow-card-registry.js"
    },
    {
      "source": "/wealthflow-feedback-ai.js",
      "destination": "/wealthflow-feedback-ai.js"
    },
    {
      "source": "/wealthflow-update-system.js",
      "destination": "/wealthflow-update-system.js"
    },
    {
      "source": "/wealthflow-dedup.js",
      "destination": "/wealthflow-dedup.js"
    },
    {
      "source": "/wealthflow-review.js",
      "destination": "/wealthflow-review.js"
    },
    {
      "source": "/wealthflow-queue.js",
      "destination": "/wealthflow-queue.js"
    },
    {
      "source": "/wealthflow-vision-sms.js",
      "destination": "/wealthflow-vision-sms.js"
    },
    {
      "source": "/wealthflow-sms-paste.js",
      "destination": "/wealthflow-sms-paste.js"
    },
    {
      "source": "/wealthflow-intel-panel.js",
      "destination": "/wealthflow-intel-panel.js"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*": {
      "includeFiles": "*.js"
    }
  },
  "crons": [
    {
      "path": "/api/release-brain",
      "schedule": "0 5 * * *"
    }
  ]
}
