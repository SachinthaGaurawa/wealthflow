{
  "entities": {
    "AppData": {
      "title": "AppData",
      "description": "Comprehensive user wealth data package",
      "type": "object",
      "properties": {
        "auth": { "type": "object" },
        "income": { "type": "array" },
        "loans": { "type": "array" },
        "ccinstall": { "type": "array" },
        "cconetime": { "type": "array" },
        "cheques": { "type": "array" },
        "expenses": { "type": "array" },
        "targets": { "type": "array" },
        "balance": { "type": "object" },
        "settings": { "type": "object" },
        "sessions": { "type": "array" }
      },
      "required": ["income", "loans", "ccinstall", "cconetime", "cheques", "expenses", "targets", "balance", "settings"]
    },
    "UserAI": {
      "title": "UserAI",
      "description": "AI interaction history and persona",
      "type": "object",
      "properties": {
        "history": { "type": "array" },
        "persona": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "AppData",
      "description": "Primary storage for user financial data"
    },
    "/userAI/{userId}": {
      "schema": "UserAI",
      "description": "AI-specific user data"
    }
  }
}
